{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/IdeaBulutSolutions/idea-almanac/packages/corpus/schema/change-entry.schema.json",
  "title": "Almanac corpus version file",
  "description": "One YAML document per Salesforce API version (data/v55.yaml). Frozen contract — schema changes require a version bump and a changelog entry.",
  "version": "1.1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["apiVersion", "release", "entries"],
  "properties": {
    "apiVersion": {
      "type": "string",
      "pattern": "^[0-9]{2}\\.0$",
      "description": "API version this file covers, e.g. \"55.0\". Every entry's apiVersion must match (enforced by the validator, §4.5)."
    },
    "release": {
      "type": "string",
      "pattern": "^(Spring|Summer|Winter) '[0-9]{2}$",
      "description": "Release name, e.g. \"Summer '22\"."
    },
    "reviewed": {
      "type": "boolean",
      "description": "Human review sign-off recorded in pipeline/review/REVIEW-LOG.md (§4.6)."
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/definitions/entry" }
    }
  },
  "definitions": {
    "entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "apiVersion",
        "release",
        "changeType",
        "impact",
        "affectedMetadataTypes",
        "behaviorArea",
        "appliesWhen",
        "summary",
        "source",
        "confidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^v[0-9]{2}-[a-z][a-z0-9-]*-[0-9]{3}$",
          "description": "v{ver}-{area}-{seq}, e.g. v55-apex-001. Stable forever."
        },
        "apiVersion": { "type": "string", "pattern": "^[0-9]{2}\\.0$" },
        "introducedIn": {
          "type": "string",
          "pattern": "^[0-9]{2}\\.0$",
          "description": "apiVersion where the change behaviorally originated, when earlier than the file's apiVersion (republished/keep-with-note entries, REVIEW-LOG rest-001/rest-015). Absent means same as apiVersion. The impact layer (§7) must use this — not file placement — for span math."
        },
        "release": { "type": "string", "pattern": "^(Spring|Summer|Winter) '[0-9]{2}$" },
        "changeType": {
          "enum": ["new", "changed", "deprecated", "removed", "retired"]
        },
        "impact": {
          "enum": ["breaking", "behavior-change", "deprecation", "retirement", "additive"]
        },
        "affectedMetadataTypes": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "enum": [
              "ApexClass",
              "ApexTrigger",
              "Flow",
              "LWC",
              "AuraDefinitionBundle",
              "VisualforcePage",
              "VisualforceComponent",
              "Integration",
              "Any"
            ]
          }
        },
        "behaviorArea": {
          "enum": [
            "apex-runtime",
            "apex-testing",
            "soql-sosl",
            "sharing-security",
            "api-rest",
            "api-soap",
            "api-bulk",
            "flow-runtime",
            "lwc",
            "aura",
            "visualforce",
            "packaging-metadata",
            "authentication",
            "other"
          ]
        },
        "appliesWhen": {
          "type": "string",
          "minLength": 10,
          "description": "Versioned-behavior trigger: e.g. \"components compiled at API >= 55.0\" vs \"org-wide regardless of component version\". The most valuable field in the corpus."
        },
        "summary": {
          "type": "string",
          "minLength": 20,
          "maxLength": 600,
          "description": "1-2 sentences, OUR OWN WORDS — never verbatim release-note text."
        },
        "detail": { "type": "string" },
        "upgradeAction": {
          "type": "string",
          "minLength": 10,
          "description": "What to test or change when crossing this version. Required for non-additive entries."
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": ["document", "page", "heading"],
          "properties": {
            "document": {
              "type": "string",
              "pattern": "^v[0-9]{2}-(spring|summer|winter)[0-9]{2}\\.pdf$"
            },
            "page": { "type": "integer", "minimum": 1 },
            "heading": { "type": "string", "minLength": 1 }
          }
        },
        "confidence": {
          "enum": ["high", "medium", "low"],
          "description": "Extraction confidence; low => mandatory human review before merge."
        }
      },
      "if": {
        "properties": { "impact": { "const": "additive" } }
      },
      "else": {
        "required": ["upgradeAction"]
      }
    }
  }
}
