{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/IdeaBulutSolutions/idea-almanac/packages/scanner/schema/report.schema.json",
  "title": "Almanac scan report",
  "description": "Output of `almanac scan`. Frozen contract — schema changes require a version bump and a changelog entry. Tier names are data (retirement-schedule.json), so `tier` is a free string here; the invariant that every non-current item carries retirementDate+tierLabel is enforced by tests.",
  "version": "1.2.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "scanner",
    "mode",
    "target",
    "schedule",
    "nonBreakingFloor",
    "debtScore",
    "debtScoreBreakdown",
    "headlines",
    "summary",
    "components",
    "integrations",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "generatedAt": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T" },
    "scanner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "mode": { "enum": ["repo", "org"] },
    "target": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "path": { "type": "string" },
        "org": { "type": "string" }
      }
    },
    "schedule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentApiVersion", "source"],
      "properties": {
        "currentApiVersion": { "type": "string", "pattern": "^[0-9]{2}\\.0$" },
        "source": { "type": "string", "description": "Path or identifier of the retirement-schedule file used." }
      }
    },
    "nonBreakingFloor": {
      "type": "string",
      "pattern": "^[0-9]+\\.0$",
      "description": "Lowest API version that clears all dated (stops-working) tiers — the nearest non-breaking target."
    },
    "debtScore": { "type": "number", "minimum": 0, "maximum": 100 },
    "debtScoreBreakdown": {
      "type": "object",
      "additionalProperties": false,
      "description": "Why the debt score is what it is: formula, per-tier contributions, and a plain-language band.",
      "required": ["formula", "totalItems", "weightedSum", "score", "band", "interpretation", "contributions"],
      "properties": {
        "formula": { "type": "string" },
        "totalItems": { "type": "integer", "minimum": 0 },
        "weightedSum": { "type": "number", "minimum": 0 },
        "score": { "type": "number", "minimum": 0, "maximum": 100 },
        "band": { "enum": ["clean", "low", "moderate", "high", "severe"] },
        "interpretation": { "type": "string" },
        "contributions": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["tier", "count", "weight", "contribution"],
            "properties": {
              "tier": { "type": "string" },
              "label": { "type": "string" },
              "count": { "type": "integer", "minimum": 0 },
              "weight": { "type": "number" },
              "contribution": { "type": "number" }
            }
          }
        }
      }
    },
    "headlines": {
      "type": "array",
      "description": "Pre-computed, date-led. Every reporter and prompt shows these identical dates.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["date", "count", "message"],
        "properties": {
          "date": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "count": { "type": "integer", "minimum": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["totalComponents", "totalIntegrations", "byTier"],
      "properties": {
        "totalComponents": { "type": "integer", "minimum": 0 },
        "totalIntegrations": { "type": "integer", "minimum": 0 },
        "byTier": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "apiVersion", "versionSource", "location", "tier"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string", "description": "Metadata API/developer name (e.g. AccountTrigger)." },
          "type": {
            "enum": [
              "ApexClass",
              "ApexTrigger",
              "Flow",
              "LWC",
              "Aura",
              "VisualforcePage",
              "VisualforceComponent",
              "ProjectDefault",
              "Manifest"
            ]
          },
          "apiVersion": {
            "type": ["string", "null"],
            "description": "null when undeterminable (a warning explains why)."
          },
          "versionSource": { "enum": ["explicit", "inherited"] },
          "location": { "type": "string" },
          "tier": { "type": "string" },
          "tierLabel": { "type": "string" },
          "retirementDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "severity": { "enum": ["critical", "high", "medium", "info"] }
        }
      }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["type", "clientName", "apiFamily", "apiVersion", "tier"],
        "properties": {
          "type": { "enum": ["api-usage", "soap-login"] },
          "clientName": { "type": "string" },
          "apiFamily": { "type": "string" },
          "apiVersion": { "type": "string" },
          "requestCount": { "type": "integer", "minimum": 0 },
          "tier": { "type": "string" },
          "tierLabel": { "type": "string" },
          "retirementDate": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
          "severity": { "enum": ["critical", "high", "medium", "info"] }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" },
          "location": { "type": "string" }
        }
      }
    }
  }
}
