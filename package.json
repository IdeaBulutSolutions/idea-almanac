{
  "name": "almanac",
  "version": "0.3.0",
  "private": true,
  "description": "Almanac — a seasonal record of every Salesforce release, and the scanner that reads your org against it.",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IdeaBulutSolutions/idea-almanac.git"
  },
  "engines": {
    "node": ">=22.6"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint .",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "validate": "npm run validate --workspaces --if-present",
    "ci": "npm run lint && npm run typecheck && npm test && npm run validate"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "ajv": "^8.20.0",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "idea-almanac": "^0.2.1"
  }
}
